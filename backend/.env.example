# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/netnova

# ── JWT Auth ─────────────────────────────────────────────
